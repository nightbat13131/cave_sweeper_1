; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="cave_sweeper_1"
run/main_scene="uid://dslha7ak2smw6"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GUIDE="*uid://p2jwrgjcbexr"

[display]

window/size/viewport_width=300
window/size/viewport_height=240
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/guide/plugin.cfg")

[gui]

theme/custom="uid://dn3yu2mjxgflx"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
environment/defaults/default_clear_color=Color(0.13333334, 0.1254902, 0.20392157, 1)
